---
import { CONFIG } from "@config";

const currentPath = Astro.url.pathname;
---

<nav
  id="navbar"
  class="navbar fixed top-0 left-0 z-50 w-full will-change-transform"
>
  <div class="container flex items-center justify-between py-4 font-medium md:py-5">
    <a href={CONFIG.nav.logo.href}>
      <img src={CONFIG.nav.logo.src} alt={CONFIG.nav.logo.alt} class="h-8 md:h-10" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-6 text-sm md:flex">
      {CONFIG.nav.pages.map(({ label, href, cta }) => (
        <li>
          {cta ? (
            <a
              href={href}
              class="btn btn-primary"
              style="font-size: 0.8125rem; padding: 0.375rem 0.875rem"
            >
              {label}
            </a>
          ) : (
            <a
              href={href}
              data-nav-link
              class:list={[
                "transition-colors duration-200",
                currentPath === href || currentPath.startsWith(href + "/")
                  ? "text-primary-400"
                  : "hover:text-primary-400",
              ]}
              style={
                currentPath === href || currentPath.startsWith(href + "/")
                  ? ""
                  : "color: var(--color-muted)"
              }
            >
              {label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- Mobile toggle -->
    <button
      data-menu-btn
      class="flex items-center justify-center md:hidden"
      style="color: var(--color-muted)"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <!-- Hamburger -->
      <svg
        data-icon-menu
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <!-- Close -->
      <svg
        data-icon-close
        class="hidden"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer — GSAP controls height/visibility -->
  <div
    data-menu-drawer
    class="overflow-hidden md:hidden"
    style="height: 0; visibility: hidden; border-bottom: 1px solid var(--color-border); background: rgb(from var(--color-bg) r g b / 0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
    aria-hidden="true"
  >
    <ul class="flex flex-col gap-1 px-6 py-4 text-sm">
      {CONFIG.nav.pages.map(({ label, href, cta }) => (
        <li>
          {cta ? (
            <a
              href={href}
              class="block py-2 font-medium transition-colors duration-200 text-primary-400 hover:text-primary-300"
            >
              {label}
            </a>
          ) : (
            <a
              href={href}
              data-nav-link-mobile
              class:list={[
                "block py-2 transition-colors duration-200",
                currentPath === href ? "text-primary-400" : "hover:text-primary-400",
              ]}
              style={currentPath === href ? "" : "color: var(--color-muted)"}
            >
              {label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  import gsap from "gsap";
  import { Observer } from "gsap/Observer";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(Observer, ScrollTrigger);

  let isTransitioning = false;
  let navInitialized = false;

  function updateActiveLinks(path: string) {
    document
      .querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
      .forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        const isActive = path === href || path.startsWith(href + "/");
        link.classList.toggle("text-primary-400", isActive);
        if (isActive) {
          link.style.removeProperty("color");
        } else {
          link.style.color = "var(--color-muted)";
        }
      });

    document
      .querySelectorAll<HTMLAnchorElement>("[data-nav-link-mobile]")
      .forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        const isActive = path === href;
        link.classList.toggle("text-primary-400", isActive);
        if (isActive) {
          link.style.removeProperty("color");
        } else {
          link.style.color = "var(--color-muted)";
        }
      });
  }

  function initNavAnimations() {
    const nav = document.querySelector<HTMLElement>("#navbar");
    if (!nav || navInitialized) return;
    navInitialized = true;

    ScrollTrigger.create({
      start: "top -1px",
      onEnter: () => nav.classList.add("is-scrolled"),
      onLeaveBack: () => nav.classList.remove("is-scrolled"),
    });

    Observer.create({
      tolerance: 4,
      onDown: () => {
        if (isTransitioning || window.scrollY < 5) return;
        gsap.to(nav, {
          y: "-100%",
          duration: 0.3,
          ease: "power2.in",
          overwrite: true,
        });
      },
      onUp: () => {
        if (isTransitioning) return;
        gsap.to(nav, {
          y: 0,
          duration: 0.3,
          ease: "power2.out",
          overwrite: true,
        });
      },
    });
  }

  function initMobileMenu() {
    const nav = document.querySelector<HTMLElement>("#navbar");
    if (!nav) return;
    const btn = nav.querySelector<HTMLButtonElement>("[data-menu-btn]");
    const drawer = nav.querySelector<HTMLDivElement>("[data-menu-drawer]");
    if (!btn || !drawer) return;

    if (btn.dataset.menuInit) return;
    btn.dataset.menuInit = "1";

    let menuOpen = false;
    const iconMenu = btn.querySelector<SVGElement>("[data-icon-menu]")!;
    const iconClose = btn.querySelector<SVGElement>("[data-icon-close]")!;

    function openMenu() {
      menuOpen = true;
      btn!.setAttribute("aria-expanded", "true");
      btn!.setAttribute("aria-label", "Fechar menu");
      drawer!.setAttribute("aria-hidden", "false");
      iconMenu.classList.add("hidden");
      iconClose.classList.remove("hidden");
      gsap.fromTo(
        drawer!,
        { height: 0, autoAlpha: 0 },
        { height: "auto", autoAlpha: 1, duration: 0.25, ease: "power2.out" },
      );
    }

    function closeMenu() {
      if (!menuOpen) return;
      btn!.setAttribute("aria-expanded", "false");
      btn!.setAttribute("aria-label", "Abrir menu");
      drawer!.setAttribute("aria-hidden", "true");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
      gsap.to(drawer!, {
        height: 0,
        autoAlpha: 0,
        duration: 0.2,
        ease: "power2.in",
        onComplete: () => {
          menuOpen = false;
        },
      });
    }

    btn.addEventListener("click", () => (menuOpen ? closeMenu() : openMenu()));
    drawer
      .querySelectorAll("a")
      .forEach((a) => a.addEventListener("click", closeMenu));
  }

  document.addEventListener("astro:page-load", () => {
    initNavAnimations();
    initMobileMenu();
    updateActiveLinks(window.location.pathname);
    ScrollTrigger.refresh();
  });

  document.addEventListener("astro:before-preparation", () => {
    isTransitioning = true;
  });

  document.addEventListener("astro:after-swap", () => {
    isTransitioning = false;
    updateActiveLinks(window.location.pathname);
    gsap.set("#navbar", { y: 0 });
  });
</script>
