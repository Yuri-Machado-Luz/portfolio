---
import { cn } from "@shared";

type Variant = "primary" | "outline";
type Size = "sm" | "md" | "lg" | "xl";

interface Props {
  href?: string;
  target?: string;
  rel?: string;
  title?: string;
  download?: boolean | string;
  class?: string;
  variant?: Variant;
  size?: Size;
}

const {
  variant = "outline",
  size = "md",
  class: className,
  ...props
} = Astro.props;

const variants: Record<Variant, string> = {
  primary:
    "bg-primary-700 text-white [animation:ambientGlow_3s_ease-in-out_infinite] hover:bg-primary-600 hover:scale-[1.02] active:scale-[0.98] active:bg-primary-700/90",
  outline:
    "text-white border border-white/20 bg-white/5 hover:bg-white/10 hover:border-white/30 hover:scale-[1.02] active:scale-[0.98] active:opacity-70",
};

const sizes: Record<Size, string> = {
  sm: "text-sm px-4 py-1.5",
  md: "text-sm px-5 py-2.5",
  lg: "text-base px-6 py-3",
  xl: "text-lg px-8 py-4",
};
---

<a
  class={cn(
    "inline-flex items-center gap-2 w-fit cursor-pointer rounded-full select-none transition-all duration-200 ease-out",
    variants[variant],
    sizes[size],
    className,
  )}
  {...props}
>
  <slot />
</a>
