---
import { CONFIG } from "@config";
import Icon from "@ui/Icon.astro";

interface Props {
  fullPage?: boolean;
}

const { fullPage = false } = Astro.props;
---

<section
  id="contato"
  class:list={[
    fullPage
      ? "container flex min-h-svh flex-col items-center justify-center py-32 text-center"
      : "container pt-22 md:flex md:flex-col md:justify-center md:pt-42",
  ]}
>
  <div
    class:list={[
      "border-base w-full overflow-hidden rounded-2xl",
      fullPage && "mt-16",
    ]}
  >
    <div class="grid md:grid-cols-2">
      <!-- Left: contact info -->
      <div
        class="border-t-base md:border-r-base order-2 flex flex-col justify-between p-5 md:order-1 md:border-t-0 md:p-12"
      >
        <div class="flex flex-col gap-4 md:gap-6">
          <!-- Email + WhatsApp: row on mobile, column on desktop -->
          <div class="grid grid-cols-2 gap-3 md:contents">
            <!-- Email -->
            <div class="contact-item flex items-center gap-3">
              <div
                class="border-base flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
              >
                <Icon name="mail" class="text-primary-400" />
              </div>
              <div class="min-w-0 text-sm">
                <p class="mb-0.5 text-muted">Email</p>
                <a
                  href={`mailto:${CONFIG.meta.social.email}`}
                  class="block truncate transition-colors hover:text-primary-400"
                >
                  {CONFIG.meta.social.email}
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <a
              href={`https://api.whatsapp.com/send?phone=${CONFIG.meta.social.whatsapp}&text=Ol%C3%A1!%20Vim%20atrav%C3%A9s%20do%20seu%20portf%C3%B3lio%20e%20gostaria%20de%20conversar.`}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-item flex items-center gap-3 hover:opacity-80"
            >
              <div
                class="border-base flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
              >
                <Icon name="whatsapp" class="text-primary-400" />
              </div>
              <div class="min-w-0 text-sm">
                <p class="mb-0.5 text-muted">WhatsApp</p>
                <p class="truncate">{CONFIG.meta.social.phone}</p>
              </div>
            </a>
          </div>

          <!-- Location: desktop only -->
          <div class="contact-item hidden items-center gap-3 md:flex">
            <div
              class="border-base flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
            >
              <Icon name="map-pin" class="text-primary-400" />
            </div>
            <div class="text-sm">
              <p class="mb-0.5 text-muted">Localização</p>
              <p>São Paulo, Brasil</p>
            </div>
          </div>
        </div>

        <!-- Social buttons -->
        <div
          class="border-t-base mt-4 flex justify-center gap-3 pt-4 md:mt-8 md:justify-start md:pt-8"
        >
          <a
            href={CONFIG.meta.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="border-base flex h-10 w-10 items-center justify-center rounded-full text-muted transition-opacity hover:opacity-80"
            aria-label="GitHub"
          >
            <Icon name="github" />
          </a>
          <a
            href={CONFIG.meta.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="border-base flex h-10 w-10 items-center justify-center rounded-full text-muted transition-opacity hover:opacity-80"
            aria-label="LinkedIn"
          >
            <Icon name="linkedin" />
          </a>
          <a
            href={`mailto:${CONFIG.meta.social.email}`}
            class="border-base flex h-10 w-10 items-center justify-center rounded-full text-muted transition-opacity hover:opacity-80"
            aria-label="Email"
          >
            <Icon name="mail" />
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        data-status="idle"
        class="contact-item order-1 flex flex-col gap-5 p-5 md:order-2 md:p-12"
      >
        <div>
          <label for="name" class="mb-1.5 block text-xs font-medium text-muted">
            Nome
          </label>
          <input
            id="name"
            type="text"
            name="name"
            required
            placeholder="Seu nome"
            class="border-base w-full rounded-lg bg-surface-strong px-4 py-2.5 text-sm text-text transition-colors duration-200 outline-none focus:ring-1 focus:ring-primary-500/50"
          />
        </div>

        <div>
          <label
            for="email"
            class="mb-1.5 block text-xs font-medium text-muted"
          >
            Email
          </label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="seu@email.com"
            class="border-base w-full rounded-lg bg-surface-strong px-4 py-2.5 text-sm text-text transition-colors duration-200 outline-none focus:ring-1 focus:ring-primary-500/50"
          />
        </div>

        <div class="flex flex-1 flex-col">
          <label
            for="message"
            class="mb-1.5 block text-xs font-medium text-muted"
          >
            Mensagem
          </label>
          <textarea
            id="message"
            name="message"
            required
            placeholder="Descreva brevemente o projeto, o prazo aproximado e como prefere conversar."
            class="border-base min-h-32 w-full resize-y rounded-lg bg-surface-strong px-4 py-2.5 text-sm text-text transition-colors duration-200 outline-none focus:ring-1 focus:ring-primary-500/50"
          ></textarea>
        </div>

        <input type="hidden" name="title" />
        <input type="hidden" name="time" />

        <!-- Status messages (CSS-driven by data-status) -->
        <p
          class="msg-sent bg-success-bg text-success items-center gap-2 rounded-lg p-3 text-sm"
        >
          <!-- Check icon -->
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
          Mensagem recebida. Respondo em até dois dias úteis.
        </p>
        <p class="msg-error bg-error-bg text-error rounded-lg p-3 text-sm">
          Não foi possível enviar a mensagem. Verifique a conexão e tente
          novamente.
        </p>

        <button
          type="submit"
          class="text-white w-full rounded-full bg-primary-700 py-2.5 text-sm font-medium transition-all duration-200 ease-out hover:bg-primary-600 active:bg-primary-700/90 disabled:pointer-events-none disabled:opacity-50"
        >
          <span data-btn-idle>Enviar mensagem</span>
          <span
            data-btn-sending
            class="inline-flex items-center justify-center gap-2"
          >
            <!-- Loader2 spinner -->
            <svg
              class="animate-spin"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
            Enviando...
          </span>
          <span
            data-btn-sent
            class="inline-flex items-center justify-center gap-2"
          >
            <!-- Check icon -->
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
            Enviado!
          </span>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  /* Status message visibility */
  #contact-form .msg-sent,
  #contact-form .msg-error {
    display: none;
  }
  #contact-form[data-status="sent"] .msg-sent {
    display: flex;
  }
  #contact-form[data-status="error"] .msg-error {
    display: block;
  }

  /* Button state spans */
  #contact-form [data-btn-idle],
  #contact-form [data-btn-sending],
  #contact-form [data-btn-sent] {
    display: none;
  }
  #contact-form[data-status="idle"] [data-btn-idle] {
    display: inline;
  }
  #contact-form[data-status="sending"] [data-btn-sending] {
    display: inline-flex;
  }
  #contact-form[data-status="sending"] button[type="submit"] {
    opacity: 0.6;
    pointer-events: none;
  }
  #contact-form[data-status="sent"] [data-btn-sent] {
    display: inline-flex;
  }
  #contact-form[data-status="sent"] button[type="submit"] {
    opacity: 0.6;
    pointer-events: none;
  }
</style>

<script>
  import emailjs from "@emailjs/browser";
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    if (!document.querySelector("#contato")) return;

    ctx?.revert();
    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();
      mm.add("(prefers-reduced-motion: no-preference)", () => {
        ScrollTrigger.batch(".contact-item", {
          onEnter: (els) => gsap.from(els, { autoAlpha: 0, y: 20, duration: 0.5, stagger: 0.08, ease: "power2.out" }),
          once: true, start: "top 85%",
        });
      });
    });

    const key = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
    if (key) emailjs.init(key);

    const form = document.querySelector<HTMLFormElement>("#contact-form");
    if (!form || form.dataset.listenerAttached) return;
    form.dataset.listenerAttached = "1";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const els = form.elements;
      const nameVal = (els.namedItem("name") as HTMLInputElement).value;
      (els.namedItem("title") as HTMLInputElement).value = nameVal;
      (els.namedItem("time") as HTMLInputElement).value =
        new Date().toLocaleString("pt-BR");

      form.dataset.status = "sending";

      try {
        await emailjs.sendForm(
          import.meta.env.PUBLIC_EMAILJS_SERVICE_ID!,
          import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID!,
          form,
        );
        form.dataset.status = "sent";
        form.reset();
        setTimeout(() => { form.dataset.status = "idle"; }, 5000);
      } catch {
        form.dataset.status = "error";
        setTimeout(() => { form.dataset.status = "idle"; }, 5000);
      }
    });
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
