---
import { ProfilePicture } from "@assets";
import Button from "@ui/Button.astro";
import { CONFIG } from "@config";
import { pt } from "@i18n/pt";
import TechStack from "@home/TechStack.astro";
---

<header
  id="hero"
  class="container mt-16 flex flex-col items-center py-12 md:mt-24 md:min-h-svh md:py-32"
>
  <div class="grid w-full items-center gap-8 md:grid-cols-[2fr_1fr] md:gap-12">
    <div class="order-2 flex flex-col gap-6 md:order-1">
      <div data-hero-badge>
        <span
          class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium border-base bg-surface text-muted"
        >
          <span
            class="h-1.5 w-1.5 animate-pulse rounded-full bg-primary-400"
            aria-hidden="true"></span>
          {pt.hero.badge}
        </span>
      </div>

      <h1
        class="font-display text-3xl leading-tight font-bold md:text-5xl lg:text-7xl"
        data-hero-text-reveal
        style="opacity: 0"
      >
        {CONFIG.meta.author}
      </h1>

      <p
        class="text-lg font-medium text-muted"
        data-hero-reveal
      >
        {CONFIG.meta.description}
      </p>

      <p
        class="max-w-md text-sm leading-relaxed text-muted"
        data-hero-reveal
      >
        {pt.hero.paragraph}
      </p>

      <nav class="flex flex-wrap gap-3" data-hero-reveal>
        <Button href="/sobre" variant="primary" size="lg">
          {pt.hero.cta.primary}
        </Button>
        <Button href="/projetos" variant="outline" size="lg">
          {pt.hero.cta.secondary}
        </Button>
      </nav>
    </div>

    <!-- Right: profile picture -->
    <div
      class="order-1 flex justify-center md:order-2 md:items-center md:justify-end"
    >
      <div class="hero-picture-wrap" data-hero-picture>
        <span class="picture-ring picture-ring--a" aria-hidden="true"></span>
        <span class="picture-ring picture-ring--b" aria-hidden="true"></span>
        <img
          src={ProfilePicture.src}
          alt={`Foto de ${CONFIG.meta.author}`}
          width={ProfilePicture.width}
          height={ProfilePicture.height}
          class="relative z-10 h-64 w-64 rounded-full object-cover md:h-80 md:w-80"
        />
      </div>
    </div>
  </div>

  <div class="w-full mt-auto" data-hero-techstack>
    <TechStack inline />
  </div>
</header>

<style>
  [data-hero-badge],
  [data-hero-reveal],
  [data-hero-picture],
  [data-hero-techstack] {
    opacity: 0;
  }

  .hero-picture-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .picture-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--color-primary-400) 40%, transparent);
    animation: picture-ring-pulse 2.8s ease-out infinite;
    pointer-events: none;
  }

  .picture-ring--b {
    animation-delay: 1.4s;
  }

  @keyframes picture-ring-pulse {
    0%   { transform: scale(1);    opacity: 0.7; }
    100% { transform: scale(1.55); opacity: 0;   }
  }

  @media (prefers-reduced-motion: reduce) {
    .picture-ring { animation: none; opacity: 0; }
  }
</style>

<script>
  import gsap from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  let ctx: gsap.Context | null = null;

  function init() {
    const hero = document.querySelector<HTMLElement>("#hero");
    if (!hero) return;

    ctx?.revert();

    // Se o usuário já viu o Hero recentemente (30 minutos), pular animação
    const HERO_SEEN_KEY = "hero:lastSeen";
    const HERO_TTL = 30 * 60 * 1000; // 30 minutos
    let shouldAnimate = true;
    try {
      const last = localStorage.getItem(HERO_SEEN_KEY);
      if (last && Date.now() - Number(last) < HERO_TTL) {
        shouldAnimate = false;
      }
    } catch (e) {
      // localStorage pode não estar disponível — continuar como padrão
    }

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        if (!shouldAnimate) {
          // Pular animação: aplicar estado final imediatamente
          gsap.set(
            "[data-hero-text-reveal], [data-hero-badge], [data-hero-reveal], [data-hero-picture], [data-hero-techstack]",
            { autoAlpha: 1, y: 0, scale: 1 },
          );
          return;
        }

        gsap.set("[data-hero-badge]", { autoAlpha: 0, y: 16 });
        gsap.set("[data-hero-reveal]", { autoAlpha: 0, y: 16 });
        gsap.set("[data-hero-picture]", { autoAlpha: 0, scale: 0.95 });
        gsap.set("[data-hero-techstack]", { autoAlpha: 0, y: 20 });

        SplitText.create("[data-hero-text-reveal]", {
          type: "lines",
          mask: "lines",
          autoSplit: true,
          onSplit(self) {
            const tl = gsap
              .timeline({ delay: 0.6 })
              .set("[data-hero-text-reveal]", { autoAlpha: 1 })
              .to("[data-hero-badge]", {
                autoAlpha: 1,
                y: 0,
                duration: 0.45,
                ease: "power2.out",
              })
              .from(
                self.lines,
                {
                  yPercent: 110,
                  duration: 0.7,
                  stagger: 0.12,
                  ease: "power3.out",
                },
                "<0.1",
              )
              .to(
                "[data-hero-picture]",
                { autoAlpha: 1, scale: 1, duration: 0.7, ease: "power2.out" },
                "<",
              )
              .to(
                "[data-hero-reveal]",
                {
                  autoAlpha: 1,
                  y: 0,
                  duration: 0.5,
                  stagger: 0.09,
                  ease: "power2.out",
                },
                "<0.35",
              )
              .to(
                "[data-hero-techstack]",
                { autoAlpha: 1, y: 0, duration: 0.5, ease: "power2.out" },
                "<0.2",
              );

            try {
              localStorage.setItem(HERO_SEEN_KEY, String(Date.now()));
            } catch (e) {
              // ignore
            }

            return tl;
          },
        });
      });

      mm.add("(prefers-reduced-motion: reduce)", () => {
        gsap.set(
          "[data-hero-text-reveal], [data-hero-badge], [data-hero-reveal], [data-hero-picture], [data-hero-techstack]",
          { autoAlpha: 1, y: 0, scale: 1 },
        );
      });
    }, hero);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
