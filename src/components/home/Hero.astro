---
import { ProfilePicture } from "@assets";
import Button from "@ui/Button.astro";
import { CONFIG } from "@config";
import { pt } from "@i18n/pt";
import TechStack from "@home/TechStack.astro";
---

<header
  id="hero"
  class="relative container mt-36 flex flex-col items-center overflow-hidden pt-20 pb-12 md:mt-24 md:min-h-svh md:py-32"
>
  <div
    class="grid w-full gap-8 lg:grid-cols-[2fr_1fr] lg:items-center lg:gap-12"
  >
    <div
      class="order-2 flex flex-col items-center gap-6 text-center lg:order-1 lg:items-start lg:text-left"
    >
      <div data-hero-badge>
        <span
          class="border-base inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-sm font-medium text-muted"
        >
          <span
            class="h-1.5 w-1.5 animate-pulse rounded-full bg-primary-400"
            aria-hidden="true"></span>
          {pt.hero.badge}
        </span>
      </div>

      <h1
        class="font-display text-4xl leading-tight font-bold md:text-5xl lg:text-7xl"
        data-hero-text-reveal
        style="opacity: 0"
      >
        {CONFIG.meta.author}
      </h1>

      <p class="text-lg font-medium text-muted" data-hero-reveal>
        {CONFIG.meta.description}
      </p>

      <p class="max-w-md text-sm leading-relaxed text-muted" data-hero-reveal>
        {pt.hero.paragraph}
      </p>

      <nav
        class="mt-20 flex flex-wrap justify-center gap-3 lg:mt-0 lg:justify-start"
        data-hero-reveal
      >
        <Button href="/sobre" variant="primary" size="lg">
          {pt.hero.cta.primary}
        </Button>
        <Button href="/projetos" variant="outline" size="lg">
          {pt.hero.cta.secondary}
        </Button>
      </nav>
    </div>

    <!-- Profile picture: hidden on mobile/tablet, right column on desktop -->
    <div class="hidden lg:order-2 lg:flex lg:items-center lg:justify-end">
      <div class="hero-picture-wrap" data-hero-picture>
        <span
          class="picture-ring picture-ring--a hidden md:block"
          aria-hidden="true"></span>
        <span
          class="picture-ring picture-ring--b hidden md:block"
          aria-hidden="true"></span>
        <img
          src={ProfilePicture.src}
          alt={`Foto de ${CONFIG.meta.author}`}
          width={ProfilePicture.width}
          height={ProfilePicture.height}
          class="relative z-10 h-28 w-28 rounded-full object-cover object-top md:h-80 md:w-80"
        />
      </div>
    </div>
  </div>

  <div class="mt-30 w-full lg:mt-auto" data-hero-techstack>
    <TechStack inline />
  </div>
</header>

<style>
  @media (prefers-reduced-motion: no-preference) {
    [data-hero-badge] {
      animation: hero-fade-up 0.4s ease 0.15s both;
    }
    [data-hero-picture] {
      animation: hero-fade 0.6s ease 0.1s both;
    }
    [data-hero-reveal] {
      animation: hero-fade-up 0.45s ease 0.45s both;
    }
    [data-hero-techstack] {
      animation: hero-fade-up 0.45s ease 0.65s both;
    }
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .hero-picture-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .picture-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid
      color-mix(in srgb, var(--color-primary-400) 40%, transparent);
    animation: picture-ring-pulse 2.8s ease-out infinite;
    pointer-events: none;
  }

  .picture-ring--b {
    animation-delay: 1.4s;
  }

  @keyframes picture-ring-pulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(1.55);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .picture-ring {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  let ctx: gsap.Context | null = null;

  function init() {
    const hero = document.querySelector<HTMLElement>("#hero");
    if (!hero) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        SplitText.create("[data-hero-text-reveal]", {
          type: "lines",
          mask: "lines",
          autoSplit: true,
          onSplit(self) {
            gsap.set("[data-hero-text-reveal]", { autoAlpha: 1 });
            gsap.from(self.lines, {
              yPercent: 110,
              duration: 0.7,
              stagger: 0.12,
              ease: "power3.out",
              delay: 0.2,
            });
          },
        });
      });

      mm.add("(prefers-reduced-motion: reduce)", () => {
        gsap.set("[data-hero-text-reveal]", { autoAlpha: 1 });
      });
    }, hero);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
