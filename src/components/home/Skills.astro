---
import { skills } from "@shared";
---

<div id="skills-grid" class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {
    skills.map((category) => (
      <div class="skill-card rounded-2xl p-6 border-base bg-surface">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4 text-muted">
          {category.label}
        </h3>
        <ul class="flex flex-col gap-2">
          {category.skills.map((skill) => (
            <li
              class="flex items-center gap-2 text-sm"
            >
              <span
                class="h-1.5 w-1.5 rounded-full bg-primary-500 shrink-0"
                aria-hidden="true"
              />
              {skill.name}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const grid = document.querySelector<HTMLElement>("#skills-grid");
    if (!grid) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        gsap.set(".skill-card", { autoAlpha: 0, y: 20 });

        ScrollTrigger.batch(".skill-card", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.45,
              stagger: 0.06,
              ease: "power2.out",
              overwrite: true,
            }),
          once: true,
          start: "top 90%",
        });
      });
    }, grid);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
