---
import "@styles/base/LogoLoop.css";
import {
  AstroRaw,
  DockerRaw,
  FastapiRaw,
  GitRaw,
  NextRaw,
  NodeRaw,
  PythonRaw,
  ReactRaw,
  TailwindRaw,
  TypeScriptRaw,
  ViteRaw,
} from "@assets";

interface Props {
  inline?: boolean;
}
const { inline = false } = Astro.props;

const techs = [
  { name: "TypeScript",   icon: TypeScriptRaw },
  { name: "React",        icon: ReactRaw },
  { name: "Astro",        icon: AstroRaw },
  { name: "Node.js",      icon: NodeRaw },
  { name: "Python",       icon: PythonRaw },
  { name: "Next.js",      icon: NextRaw },
  { name: "Tailwind CSS", icon: TailwindRaw },
  { name: "Docker",       icon: DockerRaw },
  { name: "Vite",         icon: ViteRaw },
  { name: "Git",          icon: GitRaw },
  { name: "FastAPI",      icon: FastapiRaw },
];
---

<div
  id="tech-stack"
  aria-hidden="true"
  class:list={["py-8", !inline && "border-t-base"]}
>
  <div
    id="logoloop-tech"
    class="logoloop logoloop--horizontal logoloop--fade logoloop--scale-hover text-muted"
    style="--logoloop-gap: 32px; --logoloop-logoHeight: 22px; --logoloop-fadeColor: var(--color-bg)"
    role="region"
    aria-label="Stack de tecnologias"
  >
    <div class="logoloop__track">
      <ul class="logoloop__list" role="list">
        {techs.map(({ name, icon }) => (
          <li class="logoloop__item" role="listitem">
            <span class="logoloop__node inline-flex items-center gap-2" title={name} aria-label={name}>
              <span class="tech-icon" aria-hidden="true" set:html={icon} />
              <span class="font-medium text-muted tracking-[0.02em] text-[13px]">{name}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .tech-icon svg {
    width: 22px;
    height: 22px;
  }
</style>

<script>
  import { LogoLoopController } from "@ui/LogoLoop";

  let loop: LogoLoopController | null = null;

  function init() {
    const el = document.querySelector<HTMLElement>("#logoloop-tech");
    if (!el) return;
    loop?.destroy();
    loop = new LogoLoopController(el, {
      speed: 55,
      direction: "left",
      pauseOnHover: true,
    });
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => loop?.destroy());
</script>
