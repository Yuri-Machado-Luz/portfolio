---
import type { SidebarEntry } from "../../types";

interface Props {
  entries: SidebarEntry[];
}

const { entries } = Astro.props;
---

<nav class="sidebar text-sm">
  <div class="sidebar-nav-header">
    <a href="/" class="sidebar-home-link">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Início
    </a>
  </div>
  <hr class="sidebar-divider" />

  {
    entries.map((entry) => {
      if (entry.type === "link") {
        return (
          <a
            href={entry.href}
            class:list={[
              "sidebar-link block rounded-lg px-3 py-1.5 transition-colors duration-150",
              entry.isCurrent
                ? "bg-primary-500/10 text-primary-400"
                : "hover:bg-white/5",
            ]}
            aria-current={entry.isCurrent ? "page" : undefined}
          >
            {entry.label}
            {entry.badge && (
              <span class="ml-2 rounded-full border px-1.5 py-0.5 text-xs">
                {entry.badge.text}
              </span>
            )}
          </a>
        );
      }

      if (entry.type === "group" || entry.type === "separator") {
        return (
          <div class="sidebar-group mb-4">
            <p class="sidebar-group-label">{entry.label}</p>
            <div class="sidebar-group-entries">
              {entry.entries.map((child) => {
                if (child.type === "link") {
                  return (
                    <a
                      href={child.href}
                      class:list={[
                        "sidebar-link block rounded-lg px-3 py-1.5 transition-colors duration-150",
                        child.isCurrent
                          ? "bg-primary-500/10 text-primary-400"
                          : "hover:bg-white/5",
                      ]}
                      aria-current={child.isCurrent ? "page" : undefined}
                    >
                      {child.label}
                    </a>
                  );
                }
                return null;
              })}
            </div>
          </div>
        );
      }
      return null;
    })
  }
</nav>

<style>
  .sidebar {
    padding: 1.5rem 1rem;
    color: var(--color-text);
  }

  .sidebar-home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
    transition:
      color 150ms ease,
      background 150ms ease;
  }

  .sidebar-home-link:hover {
    color: var(--color-text);
    background: rgb(255 255 255 / 0.05);
  }

  .sidebar-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0.5rem 0.75rem 1rem;
  }

  .sidebar-group-label {
    padding: 0.25rem 0.75rem;
    margin-bottom: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sidebar-group-entries {
    display: flex;
    flex-direction: column;
  }
</style>
