---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  class?: string;
}

const { eyebrow, title, lead, class: className = "" } = Astro.props;
---

<section class={`container pt-32 pb-16 ${className}`.trim()}>
  <div class="flex flex-col gap-8">
    <div>
      {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
      <h1 class="page-title mb-4">{title}</h1>
      {lead && <p class="page-lead">{lead}</p>}
    </div>
    <slot />
  </div>
</section>
