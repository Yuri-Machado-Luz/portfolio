---
import ProjectCard from "@ui/ProjectCard/ProjectCard.astro";

interface ProjectEntry {
  id: string;
  data: {
    title: string;
    description?: string;
    status: "ativo" | "dev" | "arquivado" | "beta";
    tags: string[];
    github?: string;
    live?: string;
    documentation?: string;
    order?: number;
    featured?: boolean;
  };
}

interface Props {
  projects: ProjectEntry[];
}

const { projects } = Astro.props;
---

{
  projects.length > 0 && (
    <section id="featured-projects" class="section-panel">
      <div class="section-inner container py-24">
        <div class="projects-header mb-12">
          <p class="eyebrow mb-3">Projetos</p>
          <h2 class="section-title mb-2">Projetos em Destaque</h2>
          <p class="projects-header-desc" style="color: var(--color-muted)">
            Alguns dos projetos que desenvolvi e mantenho.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((entry) => (
            <div class="project-card">
              <ProjectCard
                title={entry.data.title}
                description={entry.data.description}
                status={entry.data.status}
                tags={entry.data.tags}
                github={entry.data.github}
                live={entry.data.live}
                documentation={entry.data.documentation}
              />
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href="/projetos"
            class="projects-cta text-sm transition-colors duration-200 hover:text-primary-400"
            style="color: var(--color-muted)"
          >
            Ver todos →
          </a>
        </div>
      </div>
    </section>
  )
}

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const section = document.querySelector<HTMLElement>("#featured-projects");
    if (!section) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        gsap.set(".eyebrow, .section-title, .projects-header-desc", {
          autoAlpha: 0,
          y: 24,
        });
        gsap.set(".project-card", { autoAlpha: 0, y: 32 });
        gsap.set(".projects-cta", { autoAlpha: 0 });

        ScrollTrigger.batch(
          [".eyebrow", ".section-title", ".projects-header-desc"],
          {
            onEnter: (els) =>
              gsap.to(els, {
                autoAlpha: 1,
                y: 0,
                duration: 0.5,
                stagger: 0.07,
                ease: "power2.out",
                overwrite: true,
              }),
            once: true,
            start: "top 88%",
          },
        );

        ScrollTrigger.batch(".project-card", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.5,
              stagger: 0.09,
              ease: "power2.out",
              overwrite: true,
            }),
          once: true,
          start: "top 88%",
        });

        ScrollTrigger.batch(".projects-cta", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              duration: 0.4,
              ease: "power2.out",
            }),
          once: true,
          start: "top 92%",
        });
      });
    }, section);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
