---
import "@ui/LogoLoop/LogoLoop.css";
const ICON_SIZE = 22;
---

<section
  aria-hidden="true"
  class="py-8"
  style="border-top: 1px solid var(--color-border)"
  id="tech-stack"
>
  <div
    id="logoloop-tech"
    class="logoloop logoloop--horizontal logoloop--fade logoloop--scale-hover"
    style="color: var(--color-muted); --logoloop-gap: 32px; --logoloop-logoHeight: 22px; --logoloop-fadeColor: var(--color-bg)"
    role="region"
    aria-label="Stack de tecnologias"
  >
    <div class="logoloop__track">
      <ul class="logoloop__list" role="list">
        <!-- TypeScript -->
