---
interface NoteEntry {
  id: string;
  data: {
    title: string;
    description?: string;
    pubDate?: Date | null;
  };
}

interface Props {
  notes: NoteEntry[];
}

const { notes } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString("pt-BR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<section id="notes-section" class="section-panel">
  <div class="section-inner container py-24">
    <p class="eyebrow mb-3">Notas</p>
    <h2 class="section-title mb-10">Publicações recentes</h2>

    {
      notes.length > 0 ? (
        <ul class="notes-list list-none p-0 m-0 mb-8">
          {notes.map((note) => (
            <li class="notes-item">
              <a href={`/docs/notes/${note.id}`} class="article-item">
                <span class="article-title">{note.data.title}</span>
                {note.data.description && (
                  <span class="article-meta">
                    {note.data.description}
                    {note.data.pubDate && (
                      <> &mdash; {formatDate(new Date(note.data.pubDate))}</>
                    )}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="article-meta mb-8">Nenhuma publicação disponível ainda.</p>
      )
    }

    <a href="/docs" class="notes-cta btn" style="padding-left: 0; border: none">
      Ver todas as notas →
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const section = document.querySelector<HTMLElement>("#notes-section");
    if (!section) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        gsap.set(".eyebrow, .section-title", { autoAlpha: 0, y: 24 });
        gsap.set(".notes-item", { autoAlpha: 0, x: -16 });
        gsap.set(".notes-cta", { autoAlpha: 0, y: 12 });

        ScrollTrigger.batch([".eyebrow", ".section-title"], {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.5,
              stagger: 0.08,
              ease: "power2.out",
              overwrite: true,
            }),
          once: true,
          start: "top 88%",
        });

        ScrollTrigger.batch(".notes-item", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              x: 0,
              duration: 0.45,
              stagger: 0.06,
              ease: "power2.out",
              overwrite: true,
            }),
          once: true,
          start: "top 88%",
        });

        ScrollTrigger.batch(".notes-cta", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.4,
              ease: "power2.out",
            }),
          once: true,
          start: "top 92%",
        });
      });
    }, section);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
