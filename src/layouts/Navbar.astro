---
import { CONFIG } from "@config";
import { MenuRaw, CloseRaw } from "@assets";
import Button from "@ui/Button.astro";

const currentPath = Astro.url.pathname;
---

<nav
  id="navbar"
  class="navbar fixed top-0 left-0 z-50 w-full backdrop-blur-3xl will-change-transform"
>
  <div
    class="container flex items-center justify-between py-4 font-medium md:py-5"
  >
    <a href={CONFIG.nav.logo.href}>
      <img
        src={CONFIG.nav.logo.src}
        alt={CONFIG.nav.logo.alt}
        class="h-8 md:h-10"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="text-md hidden items-center gap-6 md:flex">
      {
        CONFIG.nav.pages.map(({ label, href, cta }) => (
          <li>
            {cta ? (
              <Button href={href} variant="primary" size="sm">
                {label}
              </Button>
            ) : (
              <a
                href={href}
                data-nav-link
                class:list={[
                  "transition-colors duration-200",
                  currentPath === href || currentPath.startsWith(href + "/")
                    ? "text-primary-400"
                    : "text-muted hover:text-primary-400",
                ]}
              >
                {label}
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      data-menu-btn
      class="border-base flex items-center justify-center rounded-lg p-2 text-muted transition-colors hover:text-primary-400 md:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <span data-icon-menu aria-hidden set:html={MenuRaw} />
      <span data-icon-close class="hidden" aria-hidden set:html={CloseRaw} />
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    data-menu-drawer
    class="overflow-hidden md:hidden"
    style="height: 0; visibility: hidden; border-bottom: 1px solid var(--color-border); background: rgb(from var(--color-bg) r g b / 0.97); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
    aria-hidden="true"
  >
    <nav class="flex flex-col gap-1 px-4 pt-3 pb-5">
      <!-- Início — não está no CONFIG.nav.pages, mas é útil no mobile -->
      <a
        href="/"
        data-nav-link-mobile
        class:list={[
          "flex items-center rounded-lg px-3 py-3 text-base font-medium transition-colors duration-200",
          currentPath === "/"
            ? "bg-surface text-primary-400"
            : "text-muted hover:bg-surface hover:text-primary-400",
        ]}
      >
        Início
      </a>

      {
        CONFIG.nav.pages.map(({ label, href, cta }) =>
          cta ? null : (
            <a
              href={href}
              data-nav-link-mobile
              class:list={[
                "flex items-center rounded-lg px-3 py-3 text-base font-medium transition-colors duration-200",
                currentPath === href || currentPath.startsWith(href + "/")
                  ? "bg-surface text-primary-400"
                  : "text-muted hover:bg-surface hover:text-primary-400",
              ]}
            >
              {label}
            </a>
          )
        )
      }

      <div class="border-t-base my-2"></div>

      {
        CONFIG.nav.pages
          .filter(({ cta }) => cta)
          .map(({ label, href }) => (
            <Button href={href} variant="primary" size="sm" class="w-full justify-center">
              {label}
            </Button>
          ))
      }
    </nav>
  </div>
</nav>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let isTransitioning = false;
  let navInitialized = false;
  let lastScrollY = 0;
  let lastAnimDir: "up" | "down" | null = null;

  function updateActiveLinks(path: string) {
    document
      .querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
      .forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        const isActive = path === href || path.startsWith(href + "/");
        link.classList.toggle("text-primary-400", isActive);
        if (isActive) {
          link.style.removeProperty("color");
        } else {
          link.style.color = "var(--color-muted)";
        }
      });

    document
      .querySelectorAll<HTMLAnchorElement>("[data-nav-link-mobile]")
      .forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        const isActive = path === href || (href !== "/" && path.startsWith(href + "/"));
        link.classList.toggle("text-primary-400", isActive);
        link.classList.toggle("bg-surface", isActive);
        link.style.removeProperty("color");
      });
  }

  function handleScroll() {
    if (isTransitioning) return;
    const nav = document.querySelector<HTMLElement>("#navbar");
    if (!nav) return;

    const y = window.scrollY;
    const delta = y - lastScrollY;
    lastScrollY = y;

    if (Math.abs(delta) < 4) return;

    if (delta > 0 && y > 60) {
      if (lastAnimDir === "down") return;
      lastAnimDir = "down";
      gsap.to(nav, {
        y: "-100%",
        duration: 0.3,
        ease: "power2.in",
        overwrite: true,
      });
    } else if (delta < 0) {
      if (lastAnimDir === "up") return;
      lastAnimDir = "up";
      gsap.to(nav, {
        y: 0,
        duration: 0.3,
        ease: "power2.out",
        overwrite: true,
      });
    }
  }

  function initNavAnimations() {
    const nav = document.querySelector<HTMLElement>("#navbar");
    if (!nav || navInitialized) return;
    navInitialized = true;

    ScrollTrigger.create({
      start: "top -1px",
      onEnter: () => nav.classList.add("is-scrolled"),
      onLeaveBack: () => nav.classList.remove("is-scrolled"),
    });

    window.addEventListener("scroll", handleScroll, { passive: true });
  }

  function initMobileMenu() {
    const nav = document.querySelector<HTMLElement>("#navbar");
    if (!nav) return;
    const btn = nav.querySelector<HTMLButtonElement>("[data-menu-btn]");
    const drawer = nav.querySelector<HTMLDivElement>("[data-menu-drawer]");
    if (!btn || !drawer) return;

    if (btn.dataset.menuInit) return;
    btn.dataset.menuInit = "1";

    let menuOpen = false;
    const iconMenu = btn.querySelector<SVGElement>("[data-icon-menu]")!;
    const iconClose = btn.querySelector<SVGElement>("[data-icon-close]")!;

    function openMenu() {
      menuOpen = true;
      btn!.setAttribute("aria-expanded", "true");
      btn!.setAttribute("aria-label", "Fechar menu");
      drawer!.setAttribute("aria-hidden", "false");
      iconMenu.classList.add("hidden");
      iconClose.classList.remove("hidden");
      gsap.fromTo(
        drawer!,
        { height: 0, autoAlpha: 0 },
        { height: "auto", autoAlpha: 1, duration: 0.25, ease: "power2.out" },
      );
    }

    function closeMenu() {
      if (!menuOpen) return;
      btn!.setAttribute("aria-expanded", "false");
      btn!.setAttribute("aria-label", "Abrir menu");
      drawer!.setAttribute("aria-hidden", "true");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
      gsap.to(drawer!, {
        height: 0,
        autoAlpha: 0,
        duration: 0.2,
        ease: "power2.in",
        onComplete: () => {
          menuOpen = false;
        },
      });
    }

    btn.addEventListener("click", () => (menuOpen ? closeMenu() : openMenu()));
    drawer
      .querySelectorAll("a")
      .forEach((a) => a.addEventListener("click", closeMenu));
  }

  document.addEventListener("astro:page-load", () => {
    initNavAnimations();
    initMobileMenu();
    updateActiveLinks(window.location.pathname);
    requestAnimationFrame(() => ScrollTrigger.refresh());
  });

  document.addEventListener("astro:before-preparation", () => {
    isTransitioning = true;
  });

  document.addEventListener("astro:after-swap", () => {
    isTransitioning = false;
    lastScrollY = window.scrollY;
    lastAnimDir = null;
    updateActiveLinks(window.location.pathname);
    gsap.set("#navbar", { y: 0 });
  });
</script>
