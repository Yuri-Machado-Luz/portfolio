---
import ClientRouter from "astro/components/ClientRouter.astro";
import { Logo } from "@assets";
import { CONFIG } from "@config";
import "@styles/global.css";
import Analytics from "@vercel/analytics/astro";

const {
  title,
  description = CONFIG.meta.description,
  prefix = CONFIG.meta.suffix,
  image,
  canonicalUrl: customCanonicalUrl,
  noindex = false,
} = Astro.props;

const canonicalUrl = customCanonicalUrl
  ? customCanonicalUrl
  : Astro.site
    ? new URL(Astro.url.pathname, Astro.site).toString()
    : Astro.url.toString();
---

<head>
  <meta charset="utf-8" />
  <ClientRouter />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href={Logo.src} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Inter:wght@300..900&family=JetBrains+Mono:wght@300..700&display=swap"
  />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <title>{title ? `${title}${prefix}` : "Yuri Machado"}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <meta property="og:title" content={title ?? "Yuri Machado"} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:description" content={description} />
  {image && <meta property="og:image" content={image} />}
  <Analytics />
</head>

<script>
  document.addEventListener("astro:before-preparation", (e) => {
    const { from, to } = e as unknown as { from: URL; to: URL };
    const fromDocs = from.pathname.startsWith("/docs");
    const toDocs = to.pathname.startsWith("/docs");
    if (fromDocs !== toDocs) {
      document.documentElement.dataset.vtCross = "docs-home";
    }
  });
  document.addEventListener("astro:after-swap", () => {
    delete document.documentElement.dataset.vtCross;
  });
</script>
