---
import Sidebar from "@ui/Sidebar.astro";
import TOC from "@ui/TOC.astro";
import Footer from "./Footer.astro";
import type { SidebarEntry } from "../types";
import Head from "./Head.astro";
import { ChevronLeftRaw, CloseRaw, MenuRaw } from "@assets";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  sidebar?: SidebarEntry[];
  headings?: Heading[];
}

const { title, description, sidebar, headings = [] } = Astro.props;
const hasSidebar = sidebar && sidebar.length > 0;
const hasToc =
  headings.filter((h) => h.depth === 2 || h.depth === 3).length > 0;
---

<html lang="pt-BR">
  <Head title={title} description={description} />

  <body>
    <main
      class="docs-layout"
      data-has-sidebar={hasSidebar ? "true" : "false"}
      data-has-toc={hasToc ? "true" : "false"}
    >
      {
        hasSidebar && (
          <aside class="docs-sidebar" transition:name="docs-sidebar">
            <div class="docs-sidebar-header">
              <button
                type="button"
                class="docs-sidebar-close"
                aria-label="Fechar navegação"
              >
                <span aria-hidden="true" set:html={CloseRaw} />
              </button>
            </div>
            <Sidebar entries={sidebar} />
            {hasToc && (
              <div class="mobile-toc-section">
                <div class="mobile-toc-divider" />
                <nav aria-label="Nesta página">
                  <p class="mobile-toc-label">Nesta página</p>
                  <ul class="mobile-toc-list">
                    {headings
                      .filter((h) => h.depth === 2 || h.depth === 3)
                      .map((heading) => (
                        <li>
                          <a
                            href={`#${heading.slug}`}
                            class:list={[
                              "mobile-toc-link",
                              heading.depth === 3 && "mobile-toc-link--h3",
                            ]}
                            data-mobile-toc-link
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                  </ul>
                </nav>
              </div>
            )}
          </aside>
        )
      }
      {
        hasSidebar && (
          <button class="sidebar-toggle" aria-label="Colapsar navegação">
            <span aria-hidden set:html={ChevronLeftRaw} />
          </button>
        )
      }

      {
        hasSidebar && (
          <div class="docs-mobile-bar">
            <button
              type="button"
              class="sidebar-mobile-toggle"
              aria-label="Abrir navegação"
              aria-expanded="false"
            >
              <span
                class="sidebar-mobile-toggle-icon"
                data-icon-menu
                aria-hidden="true"
                set:html={MenuRaw}
              />
              <span
                class="sidebar-mobile-toggle-icon is-icon-hidden"
                data-icon-close
                aria-hidden="true"
                set:html={CloseRaw}
              />
            </button>
          </div>
        )
      }

      <div class="sidebar-backdrop"></div>

      <article class="docs-content prose min-w-0">
        <h1 class="docs-title">{title}</h1>
        {description && <p class="docs-lead">{description}</p>}
        <slot />
      </article>

      {
        hasToc && (
          <aside class="docs-toc">
            <TOC headings={headings} />
          </aside>
        )
      }

      <div class="docs-footer">
        <Footer />
      </div>
    </main>
  </body>
</html>

<style>
  /* Grid layout driven by data attributes */
  .docs-layout {
    display: grid;
    min-height: 100svh;
    align-items: start;
    transition: grid-template-columns 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .docs-layout[data-has-sidebar="true"][data-has-toc="true"] {
    grid-template-columns: 16rem 1fr 14rem;
  }
  .docs-layout[data-has-sidebar="true"][data-has-toc="false"] {
    grid-template-columns: 16rem 1fr;
  }
  .docs-layout[data-has-sidebar="false"][data-has-toc="true"] {
    grid-template-columns: 1fr 14rem;
  }
  .docs-layout[data-has-sidebar="false"][data-has-toc="false"] {
    grid-template-columns: 1fr;
  }

  /* Collapsed sidebar */
  .docs-layout.sidebar-collapsed[data-has-toc="true"] {
    grid-template-columns: 0 1fr 14rem;
  }
  .docs-layout.sidebar-collapsed[data-has-toc="false"] {
    grid-template-columns: 0 1fr;
  }
  .docs-layout.sidebar-collapsed .docs-sidebar {
    border-right: none;
    overflow: hidden;
    padding: 0;
  }

  .docs-sidebar {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
    transition:
      opacity 0.25s ease,
      padding 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .docs-layout.sidebar-collapsed .docs-sidebar {
    opacity: 0;
  }

  .sidebar-toggle {
    position: fixed;
    top: 6rem;
    left: 15.5rem;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 36px;
    border-radius: 0 6px 6px 0;
    border: 1px solid var(--color-border);
    border-left: none;
    background: var(--color-surface);
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 150ms ease,
      background 150ms ease,
      left 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.25s ease;
  }
  .sidebar-toggle:hover {
    color: var(--color-text);
    background: rgb(255 255 255 / 0.08);
  }
  .docs-layout.sidebar-collapsed .sidebar-toggle {
    left: 0;
    transform: rotate(180deg);
  }

  .sidebar-mobile-toggle {
    display: none;
  }

  .docs-mobile-bar {
    display: none;
  }

  .docs-sidebar-header {
    display: none;
  }

  .sidebar-backdrop {
    display: none;
  }

  .mobile-toc-section {
    display: none;
  }

  .docs-content {
    padding: 3rem;
    max-width: none;
    overflow-x: clip;
  }

  .docs-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .docs-lead {
    font-size: 1.0625rem;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-toc {
    position: sticky;
    top: 2rem;
    padding: 0 1.5rem 3rem 0;
  }

  .docs-footer {
    grid-column: 1 / -1;
  }
  .docs-layout[data-has-sidebar="true"] .docs-footer {
    grid-column: 2 / -1;
  }
  .docs-layout.sidebar-collapsed .docs-footer {
    grid-column: 1 / -1;
  }
  .docs-footer :global(.footer) {
    margin-top: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .docs-layout[data-has-sidebar],
    .docs-layout[data-has-sidebar="true"][data-has-toc="true"],
    .docs-layout[data-has-sidebar="true"][data-has-toc="false"],
    .docs-layout.sidebar-collapsed[data-has-toc="true"],
    .docs-layout.sidebar-collapsed[data-has-toc="false"] {
      grid-template-columns: 1fr !important;
    }

    .docs-toc {
      display: none;
    }

    .docs-sidebar {
      position: fixed;
      left: 0;
      top: 0;
      height: 100dvh;
      width: 16rem;
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      border-right: 1px solid var(--color-border);
      overflow: hidden;
      padding: 0;
      opacity: 1;
    }
    .docs-sidebar.is-open {
      transform: translateX(0);
      overflow-y: auto;
      padding: initial;
    }

    .docs-sidebar-header {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0.75rem 0.75rem 0.25rem;
    }
    .docs-sidebar-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border: none;
      border-radius: 6px;
      background: transparent;
      color: var(--color-muted);
      cursor: pointer;
      transition:
        color 150ms ease,
        background 150ms ease;
    }
    .docs-sidebar-close:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.08);
    }
    .docs-sidebar-close :global(svg) {
      width: 1.125rem;
      height: 1.125rem;
      display: block;
    }

    .docs-mobile-bar {
      display: block;
      position: sticky;
      top: 0;
      z-index: 40;
      padding: 1rem 1.25rem 0;
      background: linear-gradient(
        to bottom,
        var(--color-bg) 70%,
        transparent
      );
    }

    .sidebar-toggle {
      display: none;
    }

    .sidebar-mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem;
      border-radius: 8px;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-muted);
      cursor: pointer;
      transition:
        color 150ms ease,
        background 150ms ease,
        border-color 150ms ease;
    }
    .sidebar-mobile-toggle:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.08);
    }
    .sidebar-mobile-toggle-icon {
      display: inline-flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      width: 1.25rem;
      height: 1.25rem;
    }
    .sidebar-mobile-toggle-icon :global(svg) {
      width: 1.25rem;
      height: 1.25rem;
      display: block;
    }
    .sidebar-mobile-toggle-icon.is-icon-hidden {
      display: none;
    }

    .sidebar-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 49;
      background: rgb(0 0 0 / 0.75);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .sidebar-backdrop.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .mobile-toc-section {
      display: block;
      padding: 0 1rem 1.5rem;
    }
    .mobile-toc-divider {
      height: 1px;
      background: var(--color-border);
      margin-bottom: 1.25rem;
    }
    .mobile-toc-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-muted);
      margin-bottom: 0.5rem;
    }
    .mobile-toc-list {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .mobile-toc-link {
      display: block;
      padding: 0.3125rem 0.75rem;
      border-radius: 6px;
      font-size: 0.8125rem;
      color: var(--color-muted);
      text-decoration: none;
      transition: color 150ms ease, background 150ms ease;
    }
    .mobile-toc-link:hover {
      color: var(--color-text);
      background: rgb(255 255 255 / 0.05);
    }
    .mobile-toc-link--h3 {
      padding-left: 1.25rem;
      font-size: 0.75rem;
    }

    .docs-content {
      padding: 1rem 1.25rem 2rem;
    }

    .docs-footer {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  function initDocs() {
    const layout = document.querySelector<HTMLElement>(".docs-layout");
    const sidebar = document.querySelector<HTMLElement>(".docs-sidebar");
    const toggle = document.querySelector<HTMLElement>(".sidebar-toggle");
    const mobileToggle = document.querySelector<HTMLElement>(
      ".sidebar-mobile-toggle",
    );
    const backdrop = document.querySelector<HTMLElement>(".sidebar-backdrop");

    if (layout && toggle) {
      if (localStorage.getItem("docs-sidebar-collapsed") === "true") {
        layout.classList.add("sidebar-collapsed");
      }
      toggle.addEventListener("click", () => {
        const collapsed = layout.classList.toggle("sidebar-collapsed");
        localStorage.setItem("docs-sidebar-collapsed", String(collapsed));
      });
    }

    if (sidebar && mobileToggle && backdrop) {
      const iconMenu = mobileToggle.querySelector<HTMLElement>("[data-icon-menu]");
      const iconClose = mobileToggle.querySelector<HTMLElement>("[data-icon-close]");
      const sidebarClose = sidebar.querySelector<HTMLButtonElement>(".docs-sidebar-close");

      function openSidebar() {
        sidebar!.classList.add("is-open");
        backdrop!.classList.add("is-open");
        document.body.style.overflow = "hidden";
        mobileToggle!.setAttribute("aria-expanded", "true");
        mobileToggle!.setAttribute("aria-label", "Fechar navegação");
        iconMenu?.classList.add("is-icon-hidden");
        iconClose?.classList.remove("is-icon-hidden");
      }

      function closeSidebar() {
        sidebar!.classList.remove("is-open");
        backdrop!.classList.remove("is-open");
        document.body.style.overflow = "";
        mobileToggle!.setAttribute("aria-expanded", "false");
        mobileToggle!.setAttribute("aria-label", "Abrir navegação");
        iconMenu?.classList.remove("is-icon-hidden");
        iconClose?.classList.add("is-icon-hidden");
      }

      mobileToggle.addEventListener("click", () => {
        if (sidebar!.classList.contains("is-open")) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });
      sidebarClose?.addEventListener("click", closeSidebar);
      backdrop.addEventListener("click", closeSidebar);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && sidebar!.classList.contains("is-open")) {
          closeSidebar();
          mobileToggle!.focus();
        }
      });

      sidebar.querySelectorAll<HTMLAnchorElement>("[data-mobile-toc-link]").forEach((link) => {
        link.addEventListener("click", closeSidebar);
      });
    }
  }

  document.addEventListener("astro:page-load", initDocs);
</script>
