---
import { Base } from "@layouts";
import { getFeaturedProjects, getRecentNotes } from "@shared";
import AboutSection from "@home/AboutSection.astro";
import CTASection from "@home/CTASection.astro";
import FeaturedProjects from "@home/FeaturedProjects.astro";
import Hero from "@home/Hero.astro";
import NotesSection from "@home/NotesSection.astro";

const projects = await getFeaturedProjects();
const recentNotes = await getRecentNotes(4);
---

<Base>
  <main id="home-main" class="overflow-x-clip">
    <Hero />
    <AboutSection />
    <FeaturedProjects projects={projects} />
    {recentNotes.length > 0 && <NotesSection notes={recentNotes} />}
    <CTASection />
  </main>
</Base>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const main = document.querySelector<HTMLElement>("#home-main");
    if (!main) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();
      mm.add("(prefers-reduced-motion: no-preference)", () => {
        const sections = [
          { id: "#about",            xFrom: -50, selectors: ".section-title, .about-bio p, .about-cta, .stat-item" },
          { id: "#featured-projects", xFrom:  50, selectors: ".eyebrow, .section-title, .projects-header-desc, .project-card, .projects-cta" },
          { id: "#notes-section",    xFrom: -50, selectors: ".eyebrow, .section-title, .notes-item, .notes-cta" },
          { id: "#cta-section",      xFrom:  50, selectors: ".section-title, .cta-btn, .social-link" },
        ] as const;

        sections.forEach(({ id, xFrom, selectors }) => {
          const section = main.querySelector(id);
          if (!section) return;
          const items = section.querySelectorAll(selectors);
          if (!items.length) return;

          gsap.from(items, {
            autoAlpha: 0,
            x: xFrom,
            duration: 0.55,
            stagger: 0.06,
            ease: "power2.out",
            scrollTrigger: {
              trigger: section,
              start: "top 85%",
              once: true,
            },
          });
        });
      });
    }, main);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>

