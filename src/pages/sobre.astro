---
import { CONFIG } from "@config";
import { Base } from "@layouts";
import { education, experience, languages, stats } from "@shared";
import Skills from "@home/Skills.astro";
import Button from "@ui/Button.astro";
import DownloadIcon from "@ui/DownloadIcon.astro";
import Icon from "@ui/Icon.astro";
import { pt } from "@i18n/pt";
---

<Base
  title="Sobre — Yuri Machado Luz"
  description="Desenvolvedor Full-Stack com formação em Psicologia e ADS. Freelancer desde 2020, ex-IBM. São Paulo."
>
  <main id="sobre-main">
    <!-- Header -->
    <header class="sobre-header container pt-32 pb-16">
      <div class="grid items-center gap-8 md:grid-cols-[1fr_auto]">
        <!-- Left: title + lead + social -->
        <div class="flex flex-col gap-4">
          <p class="eyebrow">Sobre</p>
          <h1 class="page-title">Yuri Machado Luz</h1>
          <p class="page-lead">
            Desenvolvedor Full-Stack · Analista de Sistemas · São Paulo, Brasil
          </p>
          <nav class="mt-2 flex flex-wrap gap-3">
            <Button
              href={CONFIG.meta.social.github}
              target="_blank"
              rel="noopener noreferrer"
              variant="outline"
              size="sm"
            >
              <Icon name="github" size={14} />
              GitHub
            </Button>
            <Button
              href={CONFIG.meta.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              variant="outline"
              size="sm"
            >
              <Icon name="linkedin" size={14} />
              LinkedIn
            </Button>
            <Button
              href="/assets/job/curriculo-yuri-machado.pdf"
              download
              variant="outline"
              size="sm"
              aria-label="Baixar currículo em PDF"
            >
              <DownloadIcon />
              PDF
            </Button>
            <Button
              href="/assets/job/curriculo-yuri-machado.docx"
              download
              variant="outline"
              size="sm"
              aria-label="Baixar currículo em DOCX"
            >
              <DownloadIcon />
              DOCX
            </Button>
            <Button
              href="/assets/job/curriculo-yuri-machado.yaml"
              download
              variant="outline"
              size="sm"
              aria-label="Baixar currículo em YAML"
            >
              <DownloadIcon />
              YAML
            </Button>
          </nav>
        </div>

        <!-- Right: quick facts -->
        <div
          class="border-base shrink-0 animate-[ambientGlow_5s_ease-in-out_infinite] rounded-xl bg-surface px-5 py-5"
        >
          <ul class="flex flex-col gap-3">
            {
              stats.quickFacts.map((fact, i) => (
                <li class="flex items-center gap-2 text-sm text-muted">
                  <span
                    class:list={[
                      "h-1.5 w-1.5 shrink-0 rounded-full bg-primary-400",
                      i === 0 && "animate-pulse",
                    ]}
                    aria-hidden="true"
                  />
                  <span class:list={[i === 0 && "text-white font-medium"]}>
                    {fact.text}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </header>

    <!-- Bio -->
    <section id="bio" class="container mb-20">
      <h2 class="section-title mb-8">Bio</h2>
      <div class="flex flex-col gap-5 leading-[1.8] text-muted">
        <p class="bio-paragraph">
          Desenvolvedor full-stack autônomo desde 2020. Construo sistemas web,
          APIs e automações para pequenas empresas e projetos próprios — do
          back-end à interface.
        </p>
        <p class="bio-paragraph">
          Em 2024-2025, passei pela IBM como Assistente Administrativo,
          redesenhando o onboarding e reduzindo o tempo de integração de 7 para
          3 dias (−57%). Automatizei arquivamento em massa com Python e
          desenvolvi dashboard de KPIs em Excel/VBA.
        </p>
        <p class="bio-paragraph">
          Paralelo ao desenvolvimento: identidade visual, prototipagem UI/UX e
          produção de conteúdo técnico e acadêmico para clientes sob NDA.
        </p>
      </div>
    </section>

    <!-- Skills -->
    <section id="habilidades" class="container mb-20">
      <h2 class="section-title mb-2">Habilidades</h2>
      <p class="mb-10 text-muted">Stack e ferramentas que uso em produção.</p>
      <Skills />
    </section>

    <!-- Experience -->
    <section id="experiencia" class="container mb-20">
      <h2 class="section-title mb-10">Experiência</h2>
      <div class="experience-list">
        {
          experience.map((item) => (
            <div class="experience-item">
              <div class="timeline">
                <div class="timeline-dot" />
                <div class="timeline-line" />
              </div>
              <div class="body">
                <h3 class="role">{item.role}</h3>
                <div class="meta">
                  <span class="company">{item.company}</span>
                  <span class="period">{item.period}</span>
                </div>
                <ul class="bullets">
                  {item.bullets.map((bullet) => (
                    <li class="bullet">{bullet}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section id="formacao" class="container mb-20">
      <h2 class="section-title mb-8">Formação</h2>
      <div class="education-list">
        {
          education.map((edu) => (
            <article class="education-item">
              <p class="degree">{edu.degree}</p>
              <p class="institution">{edu.institution}</p>
              {edu.detail && <p class="detail">{edu.detail}</p>}
            </article>
          ))
        }
      </div>
    </section>

    <!-- Languages -->
    <section id="idiomas" class="container mb-20">
      <h2 class="section-title mb-8">Idiomas</h2>
      <div class="language-grid">
        {
          languages.map((lang) => (
            <article class="language-card">
              <span class="name">{lang.name}</span>
              <span class="level">{lang.level}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="container mt-24 mb-16 flex flex-col items-center gap-6"
      id="contato"
    >
      <Button href="/contato" variant="primary" size="xl">
        {pt.cta.button}
      </Button>
    </section>
  </main>
</Base>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const main = document.querySelector<HTMLElement>("#sobre-main");
    if (!main) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: reduce)", () => {
        gsap.set(
          ".sobre-header, .section-title, .bio-paragraph, .experience-item, .education-item, .language-card",
          { autoAlpha: 1, y: 0, x: 0 },
        );
      });

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        gsap.set(".sobre-header", { autoAlpha: 0, y: 24 });
        gsap.to(".sobre-header", {
          autoAlpha: 1,
          y: 0,
          duration: 0.7,
          ease: "power3.out",
          delay: 0.1,
        });

        gsap.set(".section-title", { autoAlpha: 0, y: 14 });
        ScrollTrigger.batch(".section-title", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.5,
              ease: "power2.out",
            }),
          once: true,
          start: "top 88%",
        });

        gsap.set(".bio-paragraph", { autoAlpha: 0, y: 16 });
        ScrollTrigger.batch(".bio-paragraph", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.55,
              stagger: 0.08,
              ease: "power2.out",
            }),
          once: true,
          start: "top 90%",
        });

        gsap.set(".experience-item", { autoAlpha: 0, x: -20 });
        ScrollTrigger.batch(".experience-item", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              x: 0,
              duration: 0.55,
              stagger: 0.1,
              ease: "power3.out",
            }),
          once: true,
          start: "top 88%",
        });

        gsap.set(".education-item, .language-card", { autoAlpha: 0, y: 20 });
        ScrollTrigger.batch(".education-item, .language-card", {
          onEnter: (els) =>
            gsap.to(els, {
              autoAlpha: 1,
              y: 0,
              duration: 0.45,
              stagger: 0.07,
              ease: "power2.out",
            }),
          once: true,
          start: "top 90%",
        });
      });
    }, main);

    // Hash-tracking via IntersectionObserver
    const ids = [
      "bio",
      "habilidades",
      "experiencia",
      "formacao",
      "idiomas",
      "contato",
    ];
    const sections = ids
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (sections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              history.replaceState(null, "", `#${entry.target.id}`);
              break;
            }
          }
        },
        { rootMargin: "-40% 0px -55% 0px" },
      );
      sections.forEach((s) => observer.observe(s));
      // Cleanup handled by astro:before-preparation → ctx.revert() kills GSAP,
      // but IntersectionObserver needs manual disconnect.
      document.addEventListener(
        "astro:before-preparation",
        () => observer.disconnect(),
        { once: true },
      );
    }

    ScrollTrigger.refresh();
  }

  function preHide() {
    if (!document.querySelector("#sobre-main")) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    gsap.set(
      ".sobre-header, .section-title, .bio-paragraph, .experience-item, .education-item, .language-card",
      { autoAlpha: 0 },
    );
  }

  document.addEventListener("astro:after-swap", preHide);
  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
