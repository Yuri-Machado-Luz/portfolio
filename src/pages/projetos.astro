---
import { Base } from "@layouts";
import { getAllProjects, getAllTools, getAllNotes } from "@shared";
import PageHeader from "@ui/PageHeader.astro";
import ProjectCard from "@ui/ProjectCard.astro";

const projects = await getAllProjects();
const tools = await getAllTools();
const notes = await getAllNotes();

const featured = projects.filter((p) => p.data.featured);
const others = projects.filter((p) => !p.data.featured);
---

<Base
  title="Projetos — Yuri Machado Luz"
  description="Projetos em produção, ferramentas, contribuições open-source e notas técnicas."
>
  <main id="projects-main">
    <PageHeader
      eyebrow="Portfólio"
      title="Projetos"
      lead="Sites, ferramentas e contribuições open-source."
      class="projects-header"
    />

    <!-- Projetos em destaque -->
    {
      featured.length > 0 && (
        <section class="container mb-20">
          <div class:list={["featured-grid", featured.length === 1 && "grid-cols-1!"]}>
            {featured.map((entry) => (
              <div class="project-card">
                <ProjectCard
                  title={entry.data.title}
                  description={entry.data.description}
                  status={entry.data.status}
                  tags={entry.data.tags}
                  github={entry.data.github}
                  live={entry.data.live}
                  documentation={entry.data.documentation}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Outros projetos -->
    {
      others.length > 0 && (
        <section class="container mb-20">
          <h2 class="section-title mb-6">Outros Projetos</h2>
          <div class="projects-grid">
            {others.map((entry) => (
              <div class="project-card">
                <ProjectCard
                  title={entry.data.title}
                  description={entry.data.description}
                  status={entry.data.status}
                  tags={entry.data.tags}
                  github={entry.data.github}
                  live={entry.data.live}
                  documentation={entry.data.documentation}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Ferramentas & Contribuições -->
    {
      tools.length > 0 && (
        <section class="container mb-20">
          <h2 class="section-title mb-6">Ferramentas &amp; Contribuições</h2>
          <div class="projects-grid">
            {tools.map((entry) => (
              <div class="project-card">
                <ProjectCard
                  title={entry.data.title}
                  description={entry.data.description}
                  status={entry.data.status}
                  tags={entry.data.tags}
                  github={entry.data.github}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Notas -->
    {
      notes.length > 0 && (
        <section class="container mb-20">
          <h2 class="section-title mb-2">Notas</h2>
          <p class="text-muted text-sm mb-8">Devlogs e registros técnicos.</p>
          <div class="notes-list">
            {notes.map((entry) => (
              <a
                href={`/docs/notes/${entry.id}`}
                class="article-item"
              >
                <span class="article-title">{entry.data.title}</span>
                {entry.data.description && (
                  <span class="article-meta">{entry.data.description}</span>
                )}
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <div class="note-tags">
                    {entry.data.tags.map((tag: string) => (
                      <span class="note-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      projects.length === 0 && tools.length === 0 && notes.length === 0 && (
        <section class="container mb-20">
          <p class="text-muted">Nenhum conteúdo disponível no momento.</p>
        </section>
      )
    }
  </main>
</Base>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const main = document.querySelector<HTMLElement>("#projects-main");
    if (!main) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      const mm = gsap.matchMedia();
      mm.add("(prefers-reduced-motion: no-preference)", () => {
        ScrollTrigger.batch(".projects-header", {
          onEnter: (els) => gsap.from(els, { autoAlpha: 0, y: 24, duration: 0.6, ease: "power3.out" }),
          once: true, start: "top 88%",
        });
        ScrollTrigger.batch(".project-card", {
          onEnter: (els) => gsap.from(els, { autoAlpha: 0, y: 20, duration: 0.5, stagger: 0.07, ease: "power2.out" }),
          once: true, start: "top 88%",
        });
      });
    }, main);
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>

<style>
  .notes-list {
    display: flex;
    flex-direction: column;
  }

  .note-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .note-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
</style>
