---
import { getCollection, render } from 'astro:content';
import Content from '@components/layouts/Content.astro';

export async function getStaticPaths() {
  const collectionNames = ['notes', 'portfolio', 'sandbox', 'automation'] as const;
  const allEntries = await Promise.all(
    collectionNames.map(col =>
      getCollection(col, ({ data }) => data.draft).then(entries =>
        entries.map(entry => ({
          params: { slug: `${col}/${entry.id}` },
          props: { entry, collection: col },
        }))
      )
    )
  );
  return allEntries.flat();
}

const { entry } = Astro.props;
const { Content: Body } = await render(entry);
---

<Content title={entry.data.title} description={entry.data.description}>
  <Body />
</Content>
